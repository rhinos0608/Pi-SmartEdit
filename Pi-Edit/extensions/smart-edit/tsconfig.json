{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noEmit": true
  },
  "include": ["index.ts", "benchmark/**/*.ts", "lib/**/*.ts", "src/**/*.ts", "test/**/*.ts"],
  "exclude": ["test/fixtures/**"]
}
